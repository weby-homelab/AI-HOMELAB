# ============================================================================
# 🧠 AI-HomeLab: Ollama + Open WebUI — Змінні середовища
# ============================================================================
# Скопіюйте цей файл у .env та налаштуйте під себе:
#   cp .env.example .env
# ============================================================================

# --- Часовий пояс ---
TZ=Europe/Kyiv

# --- Open WebUI ---
# ОБОВ'ЯЗКОВО змініть на унікальний випадковий рядок!
# Згенерувати: openssl rand -hex 32
WEBUI_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# Хост для прослуховування (127.0.0.1 = тільки локально, 0.0.0.0 = з мережі)
WEBUI_HOST=127.0.0.1

# Порт веб-інтерфейсу
WEBUI_PORT=3000

# Увімкнути авторизацію (рекомендовано)
WEBUI_AUTH=true

# --- Ollama ---
# Кількість паралельних запитів
OLLAMA_NUM_PARALLEL=2

# Максимум моделей у пам'яті одночасно
OLLAMA_MAX_LOADED_MODELS=1

# GPU VRAM ліміт (0 = автоматично, в байтах)
# Приклад для 8GB: 8589934592
OLLAMA_GPU_MEMORY=0
